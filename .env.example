# regen-near-agent — environment configuration.
#
# Copy to `.env` (which is gitignored) and fill in your own values. No secrets are
# committed. tsx loads this via `--env-file-if-exists=.env` in the npm scripts.

# ── NEAR (real on-chain credit anchor — used by `--near` / demo:near / demo:research) ──
# The funded NEAR testnet account the NearCreditIssuer signs from.
# The PRIVATE KEY is NOT stored here — the issuer reads it from
#   ~/.near-credentials/testnet/<ACCOUNT_ID>.json
# (override that location with NEAR_CREDS_PATH if your key lives elsewhere).
ACCOUNT_ID=your-account.testnet
# NEAR_CREDS_PATH=/absolute/path/to/<ACCOUNT_ID>.json

# ── Apify (real web research — used by `--research` / demo:research) ──
# Apify API token for the ApifyResearchProvider (apify/rag-web-browser Actor).
# Get one at: https://console.apify.com/account/integrations
# Without it, the live research path throws a clear error (it never silently falls
# back to canned data). The default offline path (`npm run demo`) needs no token.
APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
