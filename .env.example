# regen-near-agent — environment configuration.
#
# Copy to `.env` (which is gitignored) and fill in your own values. No secrets are
# committed. tsx loads this via `--env-file-if-exists=.env` in the npm scripts.

# ── NEAR (real on-chain credit anchor — used by `--near` / demo:near / demo:research) ──
# The funded NEAR testnet account the NearCreditIssuer signs from.
# The PRIVATE KEY is NOT stored here — the issuer reads it from
#   ~/.near-credentials/testnet/<ACCOUNT_ID>.json
# (override that location with NEAR_CREDS_PATH if your key lives elsewhere).
ACCOUNT_ID=your-account.testnet
# NEAR_CREDS_PATH=/absolute/path/to/<ACCOUNT_ID>.json

# ── Apify (real web research — used by `--research` / demo:research) ──
# Apify API token for the ApifyResearchProvider (apify/rag-web-browser Actor).
# Get one at: https://console.apify.com/account/integrations
# Without it, the live research path throws a clear error (it never silently falls
# back to canned data). The default offline path (`npm run demo`) needs no token.
APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── GLM / Z.ai / Zhipu (real reasoning LLM — used by `--glm` / demo:glm) ──
# GLM is an OpenAI-compatible chat LLM. The GlmReasoner narrates the research, score,
# and proof-plan in plain language. DOCTRINE: it only REASONS — the deterministic gate
# still makes the mint/refuse decision; GLM output never feeds the issue/refuse boolean.
# Without GLM_API_KEY, the live reasoning path throws a clear error (it never silently
# falls back to canned text). The default offline path (`npm run demo`) uses StubReasoner.
# Get a key at https://z.ai (international) or https://open.bigmodel.cn (mainland).
# VERIFY the endpoint + model against the sponsor's current docs before the demo.
GLM_API_KEY=your-glm-api-key
# Endpoint base (OpenAI-compatible). Override if the sponsor docs say otherwise.
#   international: https://api.z.ai/api/paas/v4   ·   mainland: https://open.bigmodel.cn/api/paas/v4
GLM_BASE_URL=https://api.z.ai/api/paas/v4
# Model id — keep small/fast for the demo (outputs are printed inline).
GLM_MODEL=glm-4-flash

# ── Tigris (real S3-compatible object storage — used by `--tigris` / demo:tigris) ──
# Tigris is the transparent audit-ledger backend. The TigrisLedger persists the
# proof-plan + research + final credit/refusal record for every run (issued OR refused),
# keyed by opportunity-id + ISO timestamp. It is S3-compatible, so the AWS SDK v3 S3
# client points at the Tigris endpoint with standard AWS_* credentials.
# Without these, the live ledger path throws a clear error (it never silently falls back
# to local files). The default offline path (`npm run demo`) uses LocalLedger (./.ledger/).
# Create a bucket + S3-compatible keys at https://console.tigris.dev .
TIGRIS_BUCKET=your-tigris-bucket
# Endpoint base. Override if your account uses the fly.io-hosted endpoint.
#   global: https://t3.storage.dev   ·   fly.io: https://fly.storage.tigris.dev
TIGRIS_ENDPOINT=https://t3.storage.dev
AWS_ACCESS_KEY_ID=tid_xxxxxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=tsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: override the local fallback audit-trail directory (default ./.ledger).
# LEDGER_DIR=/absolute/path/to/ledger
