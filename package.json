{
  "name": "regen-near-agent",
  "version": "0.1.0",
  "description": "An autonomous agent that scores a regenerative project, emits a proof-plan, and acts on-chain by issuing a credit tied to the proof-plan hash. Proof-plans, not certification.",
  "license": "MIT",
  "type": "commonjs",
  "scripts": {
    "demo": "tsx --env-file-if-exists=.env src/index.ts",
    "demo:near": "tsx --env-file-if-exists=.env src/index.ts --near",
    "demo:research": "tsx --env-file-if-exists=.env src/index.ts --research --near",
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "near",
    "regen",
    "agent",
    "proof-plan",
    "hackathon"
  ],
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "apify-client": "^2.23.3",
    "near-api-js": "^7.2.0"
  }
}
